<div id="<%= dom_id user %>" class="card">
  <div class="card-body">
    <div class="row align-items-center mb-4">
      <div class="col-auto">
        <%= user_avatar(user, size: 128, css_class: "border shadow-sm") %>
      </div>
      <div class="col">
        <h2 class="h4 mb-1"><%= user.name.presence || user.username %></h2>
        <p class="text-muted mb-0"><%= user.email %></p>
      </div>
    </div>

    <table class="table table-borderless mb-0">
      <tbody>
        <tr>
          <th class="ps-0 text-muted" style="width: 200px">Name ID</th>
          <td class="fw-medium"><%= user.name_id %></td>
        </tr>
        <tr>
          <th class="ps-0 text-muted">ID</th>
          <td><%= user.id %></td>
        </tr>
        <tr>
          <th class="ps-0 text-muted">Username</th>
          <td><%= user.username %></td>
        </tr>
        <tr>
          <th class="ps-0 text-muted">Name</th>
          <td><%= user.name %></td>
        </tr>
        <tr>
          <th class="ps-0 text-muted">Email</th>
          <td><%= user.email %></td>
        </tr>
        <tr>
          <th class="ps-0 text-muted">Phone</th>
          <td><%= user.phone %></td>
        </tr>
        <tr>
          <th class="ps-0 text-muted">Created at</th>
          <td><%= user.created_at.to_fs(:long) %></td>
        </tr>
        <tr>
          <th class="ps-0 text-muted">Updated at</th>
          <td><%= user.updated_at.to_fs(:long) %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
