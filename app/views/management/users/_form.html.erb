<%# locals: (user:) -%>

<%= bootstrap_form_with(model: user, url: { action: user.new_record? ? :create : :update }) do |form| %>
  <%= form.alert_message t(".error", default: "Please fix the following errors:") %>

  <% if user.avatar.attached? %>
    <div class="mb-3">
      <%= user_avatar(user, size: 100) %>
    </div>
  <% end %>
  <%= form.file_field :avatar %>
  <%= form.text_field :name_id, floating: true %>
  <%= form.text_field :name, floating: true %>
  <%= form.text_field :username, floating: true %>
  <%= form.email_field :email, floating: true %>
  <%= form.telephone_field :phone, floating: true %>
  <hr>
  <%= form.password_field :password, floating: true, autocomplete: "new-password" %>
  <%= form.password_field :password_confirmation, floating: true, autocomplete: "new-password" %>
  <% if user.persisted? %>
    <%= form.password_field :password_challenge, floating: true, autocomplete: "current-password" %>
  <% end %>
  <%= form.primary %>
<% end %>
