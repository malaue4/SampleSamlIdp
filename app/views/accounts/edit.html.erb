<% content_for :title, "Edit Account Settings" %>
<% content_for :header do %>
  <h1 class="h3 mb-0">Edit Account Settings</h1>
<% end %>

<div class="col-12 p-4">
  <%= bootstrap_form_with(model: @user, url: account_path, method: :patch) do |form| %>
    <%= form.alert_message "Please fix the following errors:" %>

    <%= form.text_field :name, floating: true %>
    <%= form.email_field :email, floating: true %>
    <%= form.telephone_field :phone, floating: true %>

    <hr class="my-4">
    <h2 class="h5 mb-3">Change Password</h2>
    <p class="text-muted small mb-3">Leave blank if you don't want to change it.</p>

    <%= form.password_field :password, floating: true, autocomplete: "new-password", label: "New Password" %>
    <%= form.password_field :password_confirmation, floating: true, autocomplete: "new-password", label: "Confirm New Password" %>

    <hr class="my-4">
    <h2 class="h5 mb-3">Current Password</h2>
    <p class="text-muted small mb-3">We need your current password to confirm your changes.</p>
    <%= form.password_field :password_challenge, floating: true, autocomplete: "current-password", required: true %>

    <div class="mt-4">
      <%= form.primary "Update Account" %>
    </div>
  <% end %>
</div>

<% content_for :footer do %>
  <%= link_to "Back to Account Overview", account_path %>
<% end %>
