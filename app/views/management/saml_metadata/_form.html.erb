<%# locals: (saml_metadatum:) -%>

<%= bootstrap_form_with(model: saml_metadatum, url: { action: saml_metadatum.new_record? ? :create : :update }) do |form| %>
  <%= form.alert_message t(".error", default: "Please fix the following errors:") %>

  <%= form.text_field :entity_id, label: "Entity ID" %>
  <%= form.url_field :metadata_url %>
  <%= form.text_area :raw_xml %>
  <%= form.text_field :fingerprint %>
  <%= form.check_box :validates_signature %>

  <%= form.primary %>
<% end %>
